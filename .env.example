# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173
API_URL=http://localhost:3001
API_BASE_URL=http://localhost:3001
PORT=3001
DB_REQUESTS_PER_SECOND=10

# ─── Database ────────────────────────────────────────
# Local Postgres — replace USER / PASSWORD with your own credentials.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/corroba

# ─── AI / Embeddings (optional — app falls back to demo / rule-based) ──
# Voyage AI embeddings — placeholder format: pa-xxxxxxxxxxxxxxxx
VOYAGE_API_KEY=
# OpenAI (LLM proof extraction) — placeholder format: sk-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=
AI_DEMO_MODE=true

# ─── Search ──────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
# Local dev default (matches docker-compose.yml); change for real deployments.
TYPESENSE_API_KEY=proofloop-typesense-key

# ─── Observability (optional) ────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_URL=http://localhost:3000

# ─── Unify GTM (main partner — outbound + intent analytics) ───────────
# TWO separate keys — do NOT mix them:
#   • Data API  secret key → header X-Api-Key   (Unify → Settings → Developers)
#   • Analytics write key  → header X-Write-Key (Unify → Settings → Web & product data)
# WARNING: sending the SECRET key to the Analytics API makes Unify expire it.
# Data API secret key — placeholder format: u_xxxxxxxxxxxxxxxx
UNIFY_API_KEY=
UNIFY_API_URL=https://api.unifygtm.com/data/v1
# Analytics write key — placeholder format: u_xxxxxxxxxxxxxxxx
UNIFY_WRITE_KEY=
UNIFY_ANALYTICS_URL=https://api.unifyintent.com/analytics/v1
# Must be an origin allow-listed for the write key in Unify.
UNIFY_ANALYTICS_ORIGIN=http://localhost:5173

# ─── Zero (partner — Proof CRM) ───────────────────────
# Zero API key — keep secret, never commit a real value.
ZERO_API_KEY=
ZERO_API_URL=https://zero.inc
ZERO_API_RECORDS_PATH=/corroba/records

# ─── Lightfern (partner — proof validation) ──────────
LIGHTFERN_API_KEY=
LIGHTFERN_API_URL=

# ─── Scaile (partner — inbound / AI-search) ──────────
SCAILE_API_KEY=
SCAILE_API_URL=
