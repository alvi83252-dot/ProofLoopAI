# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173
API_URL=http://localhost:3001
API_BASE_URL=http://localhost:3001
PORT=3001
DB_REQUESTS_PER_SECOND=10

# ─── Database (PostgreSQL) ───────────────────────────
# Database name: proofloop — run: npm run db:setup
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/proofloop
DB_URL=jdbc:postgresql://localhost:5432/proofloop
DB_USERNAME=postgres
DB_PASSWORD=
JWT_SECRET=

# ─── AI / Embeddings (optional — app falls back to demo / rule-based) ──
# Voyage AI embeddings — placeholder format: pa-xxxxxxxxxxxxxxxx
VOYAGE_API_KEY=
# OpenAI (LLM proof extraction) — placeholder format: sk-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=
AI_DEMO_MODE=true

# ─── Search ──────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
# Local dev default (matches docker-compose.yml); change for real deployments.
TYPESENSE_API_KEY=proofloop-typesense-key

# ─── Observability (optional) ────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_URL=http://localhost:3000

# ─── UnifyGTM (Data API — outbound proof sync) ──────
# Data API secret key → header X-Api-Key (Unify → Settings → Developers)
UNIFYGTM_API_KEY=
UNIFYGTM_API_URL=https://api.unifygtm.com/data/v1
UNIFYGTM_PROOF_OBJECT=company
UNIFYGTM_COMPANY_DOMAIN=BTM.com
UNIFYGTM_COMPANY_NAME=BTM.com
# Aliases supported by the API (optional if UNIFYGTM_* is set)
UNIFY_API_KEY=
UNIFY_API_URL=https://api.unifygtm.com/data/v1

# ─── Unify Analytics (intent events — separate write key) ───────────
# Analytics write key → header X-Write-Key (Unify → Settings → Web & product data)
# Do NOT use the Data API secret key here — Unify will expire it.
UNIFY_WRITE_KEY=
UNIFY_ANALYTICS_URL=https://api.unifyintent.com/analytics/v1
UNIFY_ANALYTICS_ORIGIN=http://localhost:5173

# ─── GTMengineer.dev — GTM System Generator (simulated internally) ──
GTMENGINEER_API_KEY=
GTMENGINEER_API_URL=

# ─── Faxxing — Proof Amplification Engine ────────────
FAXXING_API_KEY=
FAXXING_API_URL=

# ─── Zero — Proof CRM ────────────────────────────────
# POST/GET https://api.zero.inc/proofloop/records
ZERO_API_KEY=
ZERO_API_URL=https://api.zero.inc
ZERO_API_RECORDS_PATH=/proofloop/records

# ─── Lightfern (partner — proof validation) ──────────
LIGHTFERN_API_KEY=
LIGHTFERN_API_URL=

# ─── Scaile (partner — inbound / AI-search) ──────────
SCAILE_API_KEY=
SCAILE_API_URL=
